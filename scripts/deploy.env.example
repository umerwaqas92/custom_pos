# Copy to scripts/deploy.env and fill in values.
# deploy.env is gitignored — never commit secrets.

# --- FTP (InfinityFree) ---
FTP_HOST=ftpupload.net
FTP_USER=if0_42388904
FTP_PASS=CHANGE_ME
FTP_REMOTE_ROOT=/htdocs

# --- Local MySQL (optional: apply schema/seed on your machine) ---
# Set RUN_LOCAL_DB=1 to enable
RUN_LOCAL_DB=0
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=mzk_pos
LOCAL_DB_USER=root
LOCAL_DB_PASS=

# --- Remote MySQL (usually only works FROM the hosting server, not your laptop) ---
# InfinityFree blocks most external MySQL clients. Prefer REMOTE_INSTALL_URL.
RUN_REMOTE_DB=0
REMOTE_DB_HOST=sql213.infinityfree.com
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=if0_42388904_pos
REMOTE_DB_USER=if0_42388904
REMOTE_DB_PASS=CHANGE_ME

# One-time schema/seed via HTTP installer on the live site.
# Script uploads install.php, calls it, then deletes it.
RUN_REMOTE_INSTALL=0
SITE_URL=http://quickpos.xo.je
INSTALL_KEY=mzk-install-once

# --- Build ---
BUILD_FRONTEND=1
SMOKE_TEST=1

# Do not overwrite live api/config.php (recommended 1)
KEEP_REMOTE_CONFIG=1
